# 微信公众号
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_THUMB_MEDIA_ID=

# 飞书
# 写作：在飞书云文档编辑；发布：npm run from-feishu -- "<文档URL>" --push
FEISHU_FOLDER_TOKEN=
# 可选：默认写入目录（相对 docs/）
FEISHU_DEFAULT_DIR=blog/posts

# 小红书默认话题
XHS_DEFAULT_TOPICS=旅行,个人成长,知识分享

# CSDN / 知乎：官方开放发文有限，脚本以导出+打开编辑页为主
# 若你自行准备 Cookie，仅保存在本机，切勿提交
CSDN_HOME=https://editor.csdn.net/md/
ZHIHU_HOME=https://zhuanlan.zhihu.com/write

# 站点
SITE_URL=https://duniang818.github.io/wahaha
